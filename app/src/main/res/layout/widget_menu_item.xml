<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    tools:parentTag="android.widget.LinearLayout">

    <!-- 菜单项内容 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/selectableItemBackground"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="16pt">

        <!-- 左侧图标 -->
        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/ivLeading"
            android:layout_width="24pt"
            android:layout_height="24pt"
            android:src="@drawable/ic_launcher"
            android:scaleType="centerCrop"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.Launcher.Small"
            tools:ignore="UseAppTint" />

        <Space
            android:layout_width="16pt"
            android:layout_height="wrap_content" />

        <!-- 标题 + 副标题 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/colorTextPrimary"
                android:textSize="16pt"
                tools:text="菜单标题" />

            <TextView
                android:id="@+id/tvSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4pt"
                android:textColor="@color/colorTextSecondary"
                android:textSize="13pt"
                android:visibility="gone"
                tools:text="副标题说明"
                tools:visibility="visible" />

        </LinearLayout>

        <!-- 红点 -->
        <View
            android:id="@+id/viewRedDot"
            android:layout_width="8pt"
            android:layout_height="8pt"
            android:layout_marginEnd="6pt"
            android:background="@drawable/bg_red_dot"
            android:visibility="gone" />

        <!-- 尾部文字 -->
        <TextView
            android:id="@+id/tvTrailing"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/colorTextTertiary"
            android:textSize="13pt"
            android:visibility="gone"
            tools:text="提示文字"
            tools:visibility="visible" />

        <!-- 尾部箭头图标 -->
        <ImageView
            android:id="@+id/ivTrailing"
            android:layout_width="24pt"
            android:layout_height="24pt"
            android:src="@drawable/ic_arrow_right"
            android:tint="@color/colorTextTertiary"
            android:visibility="visible"
            tools:ignore="UseAppTint" />

    </LinearLayout>

    <!-- 分隔线 -->
    <View
        android:id="@+id/divider"
        android:layout_width="match_parent"
        android:layout_height="1pt"
        android:layout_marginStart="56pt"
        android:background="@color/colorBorderBase"
        android:visibility="visible" />

</merge>
