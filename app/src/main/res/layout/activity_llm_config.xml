<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBgSecondary"
    android:orientation="vertical">

    <com.nextflow.nftouch.widget.CommonToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="56pt" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingHorizontal="16pt"
        android:paddingTop="16pt">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Provider 选择 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="4pt"
                android:paddingBottom="8pt"
                android:text="@string/llm_config_provider"
                android:textColor="@color/colorTextPrimary"
                android:textSize="14pt"
                android:textStyle="bold" />

            <androidx.cardview.widget.CardView
                android:id="@+id/cardProvider"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardBackgroundColor="@color/colorContainerBrighten"
                app:cardCornerRadius="12pt"
                app:cardElevation="1pt">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="48pt"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="16pt">

                    <TextView
                        android:id="@+id/tvProvider"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/llm_config_select_provider"
                        android:textColor="@color/colorTextPrimary"
                        android:textSize="15pt" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="›"
                        android:textColor="@color/colorTextTertiary"
                        android:textSize="22pt"
                        android:textStyle="bold" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- API Key -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20pt"
                android:paddingHorizontal="4pt"
                android:paddingBottom="8pt"
                android:text="@string/llm_config_api_key"
                android:textColor="@color/colorTextPrimary"
                android:textSize="14pt"
                android:textStyle="bold" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/colorContainerBrighten"
                app:cardCornerRadius="12pt"
                app:cardElevation="1pt">

                <EditText
                    android:id="@+id/etApiKey"
                    android:layout_width="match_parent"
                    android:layout_height="48pt"
                    android:background="@null"
                    android:hint="@string/llm_config_api_key_hint"
                    android:inputType="textPassword"
                    android:maxLines="1"
                    android:paddingHorizontal="16pt"
                    android:singleLine="true"
                    android:textColor="@color/colorTextPrimary"
                    android:textColorHint="@color/colorTextTertiary"
                    android:textSize="15pt" />
            </androidx.cardview.widget.CardView>

            <!-- Base URL -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20pt"
                android:paddingHorizontal="4pt"
                android:paddingBottom="8pt"
                android:text="@string/llm_config_base_url"
                android:textColor="@color/colorTextPrimary"
                android:textSize="14pt"
                android:textStyle="bold" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/colorContainerBrighten"
                app:cardCornerRadius="12pt"
                app:cardElevation="1pt">

                <EditText
                    android:id="@+id/etBaseUrl"
                    android:layout_width="match_parent"
                    android:layout_height="48pt"
                    android:background="@null"
                    android:hint="@string/llm_config_base_url_hint"
                    android:inputType="textUri"
                    android:maxLines="1"
                    android:paddingHorizontal="16pt"
                    android:singleLine="true"
                    android:textColor="@color/colorTextPrimary"
                    android:textColorHint="@color/colorTextTertiary"
                    android:textSize="15pt" />
            </androidx.cardview.widget.CardView>

            <!-- Model Name -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20pt"
                android:paddingHorizontal="4pt"
                android:paddingBottom="8pt"
                android:text="@string/llm_config_model_name"
                android:textColor="@color/colorTextPrimary"
                android:textSize="14pt"
                android:textStyle="bold" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/colorContainerBrighten"
                app:cardCornerRadius="12pt"
                app:cardElevation="1pt">

                <EditText
                    android:id="@+id/etModelName"
                    android:layout_width="match_parent"
                    android:layout_height="48pt"
                    android:background="@null"
                    android:hint="@string/llm_config_model_name_hint"
                    android:inputType="text"
                    android:maxLines="1"
                    android:paddingHorizontal="16pt"
                    android:singleLine="true"
                    android:textColor="@color/colorTextPrimary"
                    android:textColorHint="@color/colorTextTertiary"
                    android:textSize="15pt" />
            </androidx.cardview.widget.CardView>

            <com.nextflow.nftouch.widget.KButton
                android:id="@+id/btnSave"
                android:layout_width="match_parent"
                android:layout_height="48pt"
                android:layout_marginTop="32pt"
                android:text="@string/common_save"
                android:textSize="16pt" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>
